#!/usr/bin/env bash
#
# opendbx pre-push hook — spec-0.7 D-5 / T-8.
#
# Validates `git push origin v*` (tag pushes) against 5 invariants before
# the push reaches the remote. Auto-installed via `make hooks-install`
# (SRC_HOOKS wildcard pickup; Makefile spec-0.1 D-2).
#
# Invariants (spec-0.7 § 2.5):
#
#   1. Tag name matches VersionPattern (regex source: D-1 grammar.go).
#   2. Tag is annotated (not lightweight; defends message-schema check).
#   3. Tag's peeled commit == refs/heads/main HEAD (no detached refs;
#      claude HIGH-3 correction: peel via `^{}` not "current commit").
#   4. Tag message contains canonical 5-field schema (spec § 2.7):
#      Spec: / Repo: / Commit: / Peer-Repo: / Peer-Commit:.
#   5. Reject tag update or delete pushes (annotated tags are immutable
#      after first push; CLAUDE.md 规则 14 main protection extends to tags).
#      Override: OPENDBX_TAG_REPAIR=1 env (used by tag-spec.sh
#      --repair-missing-peer mode).
#
# Bypass: git push --no-verify   (emergency only; document in CHANGELOG)

set -euo pipefail

# git pre-push protocol: each ref to be pushed is read from stdin as:
#   <local_ref> <local_sha> <remote_ref> <remote_sha>
#
# For tag pushes: local_ref = refs/tags/<name>, remote_ref = refs/tags/<name>.
# Delete: local_sha = 0000...; remote_sha != 0000.
# Update: both shas non-zero AND differ.
# Create: local_sha != 0000 AND remote_sha = 0000.

# Zero-sha sentinel that git uses to mean "no commit" (40-char literal).
ZERO_SHA="0000000000000000000000000000000000000000"

# Source pattern matches the one in grammar.go (spec-0.7 D-1).
# Capture groups: 1=MAJOR, 2=MINOR, 3=PATCH, 4=Stage, 5=SpecN, 6=accepted suffix.
VERSION_PATTERN='^v[0-9]+\.[0-9]+\.[0-9]+-stage[0-9]+\.[0-9]+(-accepted)?$'

# Canonical message strict line-by-line check is implemented inline in
# validate_tag_ref (T-12 H3 codex fix); no per-field list needed here.

err() { echo >&2 "ERROR: pre-push: $*"; }

# tag_ref / local_tag / remote_tag are loop-locals used in main loop;
# declared up-front so shellcheck SC2154 doesn't complain.
tag_ref=""
local_tag=""
remote_tag=""

# Reject single ref. Echoes diagnostic to stderr. Returns 1 if invalid.
validate_tag_ref() {
    local local_ref="$1" local_sha="$2" remote_sha="$3"
    local tag="${local_ref#refs/tags/}"

    # 5. Reject delete + update (annotated tag immutability) unless repair env.
    if [[ "${OPENDBX_TAG_REPAIR:-0}" != "1" ]]; then
        if [[ "$local_sha" == "$ZERO_SHA" ]]; then
            err "tag delete blocked for $tag (CLAUDE.md 规则 14: tags are immutable). Set OPENDBX_TAG_REPAIR=1 to override."
            return 1
        fi
        if [[ "$remote_sha" != "$ZERO_SHA" && "$remote_sha" != "$local_sha" ]]; then
            err "tag update blocked for $tag (existing remote $remote_sha != local $local_sha). Set OPENDBX_TAG_REPAIR=1 to override."
            return 1
        fi
    fi

    # 1. VersionPattern match.
    if [[ ! "$tag" =~ $VERSION_PATTERN ]]; then
        err "tag $tag violates VersionPattern (spec-0.7 § 2.1)"
        err "  expected: v<MAJOR>.<MINOR>.<PATCH>-stage<S>.<N>[-accepted]"
        return 1
    fi

    # 2. Annotated tag check (`git cat-file -t` returns "tag" for annotated,
    #    "commit" for lightweight pointing directly to a commit).
    local tag_type
    tag_type=$(git cat-file -t "$tag" 2>/dev/null || echo "missing")
    if [[ "$tag_type" != "tag" ]]; then
        err "tag $tag is $tag_type, must be annotated (use \`git tag -a $tag -m ...\` or scripts/release/tag-spec.sh)"
        return 1
    fi

    # 3. Tag's peeled commit == main HEAD (claude HIGH-3 correction).
    local tag_target main_head
    tag_target=$(git rev-parse "${tag}^{}" 2>/dev/null) || {
        err "could not peel tag $tag to commit"
        return 1
    }
    main_head=$(git rev-parse refs/heads/main 2>/dev/null) || {
        err "could not resolve refs/heads/main (is main checked out / fetched?)"
        return 1
    }
    if [[ "$tag_target" != "$main_head" ]]; then
        err "tag $tag points to $tag_target, not main HEAD $main_head"
        err "  hint: tags must mark the same commit as main HEAD (use scripts/release/tag-spec.sh)"
        return 1
    fi

    # 4. Canonical 5-field message schema (codex T-12 H3 fix: strict
    #    ordered parse, value validation — not just field-presence).
    #
    #    Required exact order + value rules:
    #      line 1: "Spec: spec-<id>-<slug>"           (free-form value, just non-empty)
    #      line 2: "Repo: opendbx"                    (this repo; literal match)
    #      line 3: "Commit: <12-char>"                (must equal git rev-parse --short=12 tag^{})
    #      line 4: "Peer-Repo: opendbrb"              (literal match)
    #      line 5: "Peer-Commit: <12-char>"           (non-empty 12-hex)
    #    Trailing newlines tolerated; no extra non-empty lines allowed.
    local tag_msg
    tag_msg=$(git tag -l --format='%(contents)' "$tag")
    # Strip trailing blank lines for the line-count check; keep order intact.
    local stripped_msg
    stripped_msg=$(printf '%s' "$tag_msg" | awk 'NR==1{out=$0; next} {out=out"\n"$0} END{sub(/\n+$/,"",out); print out}')
    local line_count
    line_count=$(printf '%s\n' "$stripped_msg" | grep -cv '^[[:space:]]*$' || true)
    if [[ "$line_count" -ne 5 ]]; then
        err "tag $tag canonical message must have exactly 5 non-empty lines (got $line_count)"
        err "  hint: use scripts/release/tag-spec.sh (opendbrb) for canonical generation"
        return 1
    fi
    local line1 line2 line3 line4 line5
    line1=$(sed -n '1p' <<< "$stripped_msg")
    line2=$(sed -n '2p' <<< "$stripped_msg")
    line3=$(sed -n '3p' <<< "$stripped_msg")
    line4=$(sed -n '4p' <<< "$stripped_msg")
    line5=$(sed -n '5p' <<< "$stripped_msg")
    [[ "$line1" =~ ^Spec:\ spec-[A-Za-z0-9.-]+$ ]] || { err "tag $tag line 1 not 'Spec: spec-...': $line1"; return 1; }
    [[ "$line2" == "Repo: opendbx" ]] || { err "tag $tag line 2 must be 'Repo: opendbx' (got: $line2)"; return 1; }
    [[ "$line3" =~ ^Commit:\ [0-9a-f]{12}$ ]] || { err "tag $tag line 3 not 'Commit: <12-hex>': $line3"; return 1; }
    [[ "$line4" == "Peer-Repo: opendbrb" ]] || { err "tag $tag line 4 must be 'Peer-Repo: opendbrb' (got: $line4)"; return 1; }
    [[ "$line5" =~ ^Peer-Commit:\ [0-9a-f]{12}$ ]] || { err "tag $tag line 5 not 'Peer-Commit: <12-hex>': $line5"; return 1; }

    # 4b. Commit value must equal actual git rev-parse --short=12 of the tag target.
    local expected_commit actual_commit
    expected_commit=$(git rev-parse --short=12 "${tag}^{}" 2>/dev/null)
    actual_commit="${line3#Commit: }"
    if [[ "$actual_commit" != "$expected_commit" ]]; then
        err "tag $tag Commit field $actual_commit != actual tag target $expected_commit"
        err "  hint: the canonical message must reference the same commit the tag points to"
        return 1
    fi

    return 0
}

# Read stdin (pre-push protocol) and validate every v* tag ref.
#
# Protocol per `git help githooks` (pre-push):
#   <local_ref> <local_sha> <remote_ref> <remote_sha>
# Special values:
#   - delete: local_ref="(delete)", local_sha=zero-sha, remote_ref="refs/tags/<name>"
#   - create: local_ref="refs/tags/<name>", remote_sha=zero-sha
#   - update: both shas non-zero, local_sha != remote_sha
#
# codex T-12 H1 fix: delete protocol uses local_ref="(delete)" not the tag
# ref, so the prior `case "$local_ref" in refs/tags/v*` filter let deletes
# bypass invariant 5. Now both local_ref and remote_ref are inspected.
failed=0
while read -r local_ref local_sha remote_ref remote_sha; do
    # Identify the tag name from whichever side has the refs/tags/v* shape.
    local_tag=""
    case "$local_ref" in
        refs/tags/v*) local_tag="$local_ref" ;;
    esac
    remote_tag=""
    case "$remote_ref" in
        refs/tags/v*) remote_tag="$remote_ref" ;;
    esac
    # Skip if neither side is a v* tag.
    if [[ -z "$local_tag" && -z "$remote_tag" ]]; then
        continue
    fi
    # Resolve the tag-name ref (prefer local if present; on delete local
    # is "(delete)" so fall back to remote_ref).
    tag_ref="${local_tag:-$remote_tag}"
    if ! validate_tag_ref "$tag_ref" "$local_sha" "$remote_sha"; then
        failed=1
    fi
done

if [[ "$failed" == "1" ]]; then
    err "one or more tag pushes rejected. Use --no-verify only in emergencies."
    exit 1
fi

exit 0
